{% extends 'base.html.twig' %}

{% block title %}Nos Rayons{% endblock %}

{% block body %}

    <div class="card-header">
        <a class="btn-back text-secondary" href="{{ path('app_default_index') }}">
            <i class="fas fa-2x fa-arrow-circle-left"></i>
        </a>
        <h3>
            <i class="fas fa-store"></i>
            Boutique
            <span class="badge badge-pill badge-info">{{ categories | length  }}</span>
            rayon(s) proposé(s)
        </h3>
    </div>
    <div class="card-body row">
        {% for article in categories %}
        <div class="col-md-3">
            <div class="card clickable" onclick="location = '{{ path('app_boutique_rayon',{ 'idCategorie': article.id }) }}'">
                <img src="{{ asset(article.visuel) }}" class="card-img-top" alt="{{ article.libelle }}">
                <div class="card-body">
                    <h4 class="card-title">{{ article.libelle }}</h4>
                    <p class="card-text">
                        <i>{{ article.texte }}</i>
                    </p>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endblock %}
