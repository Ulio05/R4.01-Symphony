{% extends 'base.html.twig' %}

{% block title %}Hello PanierController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>
    {% if nbProduit == 0 %}

    <div class="card col-md-12">
        <div class="card-header">
            <a class="btn-back text-secondary" href="/info/R401/fr/boutique/">
                <i class="fas fa-2x fa-arrow-circle-left"></i>
            </a>
            <h3>
                <i class="fas fa-shopping-cart"></i>
                <span class="badge badge-pill badge-danger">0</span>
                produit(s) - montant :
                <b>0,00&nbsp;€</b>
            </h3>
        </div>
        <div class="card-body">
            <h5>
                <i>Ton panier est vide !<br>
                    Voudrais-tu briser notre petit coeur fragile de commerçant ?<br><br>
                </i>
                <a href="/info/R401/fr/boutique/">
                    <i class="fas fa-2x fa-heart-broken text-danger text-blink"></i>
                </a>
            </h5>
        </div>
    </div>
    {% else %}
        <div class="card col-md-12">
            <div class="card-header">
                <a class="btn-back text-secondary" href="{{ path('app_boutique_index') }}">
                    <i class="fas fa-2x fa-arrow-circle-left"></i>
                </a>
                <h3>
                    <i class="fas fa-shopping-cart"></i>
                    <span class="badge badge-pill badge-info">1</span>
                    produit(s) - montant :
                    <b>{{ prixTotal }}€</b>
                </h3>
                <div class="col-md-6 align-self-center btn-group btn-group" role="group">
                    <a class="btn btn-primary" href="/info/R401/fr/panier/commander">
                        Passer la commande
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <table class="table table-striped table-sm table-hover">
                        <thead>
                        <tr>
                            <th></th>
                            <th>Produit</th>
                            <th class="text-right">Prix</th>
                            <th>Quantité</th>
                            <th class="text-right">Total</th>
                            <th>Supprimer</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for article in panier %}
                        <tr>
                            <td>
                                <img src="{{ asset(article.produit.visuel) }}" class="cart-img-produit" alt="{{ article.produit.libelle }}">
                            </td>
                            <td>
                                <a href="{{path('app_boutique_rayon',{ 'idCategorie': article.produit.id }) }}">
                                    <b>{{ article.produit.libelle }}</b>
                                </a>
                            </td>
                            <td class="text-right">
                                {{ article.produit.prix }}€
                            </td>
                            <td>
                                <a href="/info/R401/fr/panier/enlever/1">
                                    <i class="fas fa-minus-square text-muted"></i>
                                </a>
                                1
                                <a href="/info/R401/fr/panier/ajouter/1">
                                    <i class="fas fa-plus-square text-muted"></i>
                                </a>
                            </td>
                            <td class="text-right">
                                {{ article.produit.prix*article.quantite }}€
                            </td>
                            <td>
                                <a href="/info/R401/fr/panier/supprimer/1">
                                    <i class="fas fa-trash text-muted" data-toggle="tooltip" title="" data-placement="right" data-html="true" data-original-title="Supprimer &lt;b&gt;{{ article.produit.libelle }}&lt;/b&gt;"></i>
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                        </tbody>
                        <tfoot>
                        <tr>
                            <th class="text-right" colspan="4">
                                Total
                            </th>
                            <th class="text-right">
                                {{ prixTotal}}€
                            </th>
                            <th>
                                <a href="/info/R401/fr/panier/vider">
                                    <i class="fas fa-trash text-muted" data-toggle="tooltip" title="" data-placement="right" data-html="true" data-original-title="Vider tout le Panier"></i>
                                </a>
                            </th>
                        </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
